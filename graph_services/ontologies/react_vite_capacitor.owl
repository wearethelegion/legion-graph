<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rvc="http://kgrag.ai/ontology/react_vite_capacitor#">

  <!-- ═══════════════════════════════════════════════════════════════════
       React + Vite + Capacitor Code Ontology
       Version: 1.0
       Purpose: Guide Cognee entity extraction for React/Vite/Capacitor
                mobile codebases (Android/iOS).
       Classes: 12 (v1 — Tier 1 + selected Tier 2)
       ObjectProperties: 12
       Design: Short class names for 80% fuzzy-match compatibility.
               No NamedIndividuals — types only, instances extracted at runtime.
       ═══════════════════════════════════════════════════════════════════ -->

  <owl:Ontology rdf:about="http://kgrag.ai/ontology/react_vite_capacitor">
    <rdfs:comment>OWL ontology for React + Vite + Capacitor mobile app
    code entity extraction. Covers React UI layer, Capacitor native
    bridge, and cross-platform patterns. Used by Cognee to validate
    and canonicalize extracted entities via fuzzy matching.</rdfs:comment>
  </owl:Ontology>

  <!-- ═══════════════════════════════════════════════════════════════════
       ABSTRACT ROOT CLASS
       ═══════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity">
    <rdfs:comment>Root class for all code entities in a React+Vite+Capacitor app.</rdfs:comment>
  </owl:Class>

  <!-- ═══════════════════════════════════════════════════════════════════
       TIER 1 — CORE ENTITIES (7 classes)
       Names kept short for fuzzy-match at 80% threshold.
       ═══════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Component">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A React component (functional or class-based). The fundamental
    UI building block. Includes page components, layout components,
    form components, and presentational components.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Hook">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A React hook — built-in (useState, useEffect, useContext) or
    custom (functions starting with use). Custom hooks wrapping
    Capacitor plugins (useCamera, useGeolocation) are the central
    pattern bridging React and native APIs.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Plugin">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A Capacitor plugin providing native device access. Includes
    official plugins (@capacitor/camera, @capacitor/geolocation),
    community plugins, and custom local plugins. THE differentiating
    entity of a Capacitor codebase vs. a plain React web app.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Route">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A route definition mapping a URL path to a component. Defined
    via react-router-dom, TanStack Router, or similar. Deep links
    map external URLs to routes.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Context">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A React Context — createContext + Provider + useContext triplet.
    Provides dependency injection and scoped state. In Capacitor apps,
    contexts often wrap platform-specific state (NetworkContext,
    AuthContext).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Store">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A state management construct — useState, useReducer, Zustand
    store, Redux slice, Jotai atom, Recoil atom, MobX observable.
    State persistence via Capacitor Preferences or SQLite adds
    a mobile-specific dimension.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Page">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:comment>A page-level component mapped to a route. Represents a full
    screen in the mobile app (e.g., /dashboard, /profile, /settings).
    The unit of navigation.</rdfs:comment>
  </owl:Class>

  <!-- ═══════════════════════════════════════════════════════════════════
       TIER 2 — CAPACITOR-SPECIFIC + PROMOTED (5 classes)
       These differentiate this ontology from generic React.
       ═══════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#NativeModule">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>Custom native code implementing a Capacitor plugin. On iOS:
    Swift class extending CAPPlugin. On Android: Java/Kotlin class
    annotated with @CapacitorPlugin. The native side of the bridge.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#PlatformGuard">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>Conditional code checking the current platform (iOS/Android/Web)
    and branching behavior. Unique to hybrid/cross-platform apps.
    Detection: Capacitor.isNativePlatform(), Capacitor.getPlatform().</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#DeepLinkHandler">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>Code handling incoming deep links (universal links on iOS,
    app links on Android). Listens to App.addListener('appUrlOpen')
    and routes to the appropriate in-app screen.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#Service">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>A service function or module handling API communication, data
    fetching, or external service integration. Includes fetch/axios
    calls, React Query functions, CapacitorHttp calls. Defines the
    app's backend integration surface.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#PluginRegistration">
    <rdfs:subClassOf rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:comment>The registerPlugin('PluginName') call from @capacitor/core that
    creates a JavaScript proxy object bridging to native code. The
    exact point where JavaScript meets native. Must match the
    native-side @CapacitorPlugin annotation.</rdfs:comment>
  </owl:Class>

  <!-- ═══════════════════════════════════════════════════════════════════
       OBJECT PROPERTIES (12 relationships)
       Capped at 12 to limit BFS subgraph injection.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Component relationships -->
  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#renders">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:comment>Parent component renders child component in JSX.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#uses_hook">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Hook"/>
    <rdfs:comment>Component or hook calls a React hook.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#uses_plugin">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Plugin"/>
    <rdfs:comment>Code uses a Capacitor plugin for native functionality.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Routing relationships -->
  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#route_renders">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Route"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:comment>Route maps a URL path to a component.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#navigates_to">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Page"/>
    <rdfs:comment>Component navigates to a page (useNavigate, router.push).</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Context / State relationships -->
  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#provides_context">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Context"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:comment>Context provider wraps and provides values to components.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#consumes_context">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Context"/>
    <rdfs:comment>Component consumes context values via useContext().</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#manages_state">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Hook"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Store"/>
    <rdfs:comment>Hook manages or interacts with a state store.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Capacitor-specific relationships -->
  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#bridges_to">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#PluginRegistration"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#NativeModule"/>
    <rdfs:comment>JS plugin registration bridges to native implementation.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#checks_platform">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#CodeEntity"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#PlatformGuard"/>
    <rdfs:comment>Code checks platform before conditional execution.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#handles_deeplink">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#DeepLinkHandler"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Route"/>
    <rdfs:comment>Deep link handler maps incoming URL to a route.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kgrag.ai/ontology/react_vite_capacitor#calls_service">
    <rdfs:domain rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Component"/>
    <rdfs:range rdf:resource="http://kgrag.ai/ontology/react_vite_capacitor#Service"/>
    <rdfs:comment>Component calls a service for API or backend interaction.</rdfs:comment>
  </owl:ObjectProperty>

</rdf:RDF>
