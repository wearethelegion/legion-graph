# ══════════════════════════════════════════════════════════════════════════════
# KGRAG Environment Configuration — Example
# Copy this to .env and fill in your values.
#
# RULE: Every host reference here must use a DOCKER SERVICE NAME
# (postgres, qdrant, neo4j, redis, redpanda, kgrag-auth, kgrag-cognee, ...)
# NOT localhost. Containers reach each other by service name.
#
# ⚠ VALIDATION STATUS: This file ships with the only LLM configuration that
# has been end-to-end tested: Gemini 3.1 Flash Lite Preview via the Gemini API.
# Any other provider/model in the examples below is reachable via LiteLLM but
# has NOT been verified against this stack. Switching providers will likely
# require tuning of prompts, instructor mode, embedding dimensions, and rate
# limits. Use untested configurations at your own risk.
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: Secrets you MUST set ──────────────────────────────────────────
# GEMINI_API_KEY: despite the name, this is the universal LLM API-key slot.
# docker-compose.yml fans this value out to all services as LLM_API_KEY.
# Use any LiteLLM-supported provider (OpenAI, Anthropic, Gemini, OpenRouter,
# Azure, Bedrock, Ollama, etc.) — just also set LLM_PROVIDER and LLM_MODEL
# below to match. Gemini is the default because it has a generous free tier.
# Examples:
#   Gemini      LLM_PROVIDER=gemini LLM_MODEL=gemini/gemini-3.1-flash-lite-preview   ← tested default
#   OpenAI      LLM_PROVIDER=openai LLM_MODEL=gpt-4o-mini
#   OpenRouter  LLM_PROVIDER=openai LLM_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free  LLM_ENDPOINT=https://openrouter.ai/api/v1
#   Ollama      LLM_PROVIDER=openai LLM_MODEL=ollama/llama3  LLM_ENDPOINT=http://host.docker.internal:11434/v1
# See README.md "LLM provider choice" and .env.cognee.example for full recipes.
GEMINI_API_KEY=your_llm_provider_api_key_here
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION
COGNEE_JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION
NEO4J_PASSWORD=change_this_neo4j_password
POSTGRES_PASSWORD=change_this_postgres_password
REDIS_PASSWORD=change_this_redis_password

# TOTP encryption key — encrypts 2FA seeds in the database. Required if any
# user enables 2FA. Once set, NEVER rotate (existing seeds become unreadable).
# Read by auth/services/totp_service.py.
TOTP_ENCRYPTION_KEY=change_this_to_a_secure_random_key

# Email verification (Infobip). If you don't have Infobip credentials, set
# SKIP_EMAIL_VERIFICATION=true at the bottom of this file and these are
# ignored. Read by auth/services/email_service.py.
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
VERIFICATION_FROM_EMAIL=noreply@example.com

# [OPTIONAL] Comma-separated list of additional Gemini API keys for round-robin
# embedding-request rotation, to avoid per-key quota limits. Falls back to
# GEMINI_API_KEY (single key) when unset. Read by
# graph_services/patches/cognee/index_data_points.py.
EMBEDDING_API_KEYS=

# ── OPTIONAL: GitHub token for private repo ingestion ───────────────────────
# Stored per-project in postgres (projects.github_token). Falls back to this
# env value if a project has no token set.
GITHUB_TOKEN=

# ── Postgres (intra-container) ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kgrag
POSTGRES_DB=kgrag_auth
POSTGRES_URL=postgresql://kgrag:${POSTGRES_PASSWORD}@postgres:5432/kgrag_auth

# ── Qdrant (intra-container) ────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://qdrant:6333

# ── Neo4j / DozerDB (intra-container) ───────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# COGNEE_NEO4J_DATABASE: the Neo4j logical database cognee writes the graph
# into. Must be created once via `CREATE DATABASE cognee IF NOT EXISTS`
# against Neo4j's `system` database before first cognee run.
COGNEE_NEO4J_DATABASE=cognee
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://neo4j:7687
GRAPH_DATABASE_USERNAME=neo4j

# ── Redis (intra-container) ─────────────────────────────────────────────────
REDIS_URI=redis://redis:6379
COGNEE_REDIS_URL=redis://redis:6379
COGNEE_REDIS_STAGING_TTL=3600

# ── Kafka / Redpanda (intra-container) ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_INCOMING_TOPIC=incoming_requests
ENRICHED_CHUNKS_TOPIC=enriched-code-chunks

# ── Service-to-service URLs (intra-container) ───────────────────────────────
AUTH_SERVICE_URL=http://kgrag-auth:8001
# Primary search backend: REST API talks to kgrag-cognee on :50052 for all
# brain/code search traffic. This is the path the validated E2E exercises.
COGNEE_SERVICE_URL=kgrag-cognee:50052
# Legacy gRPC frontend on :50051 (kgrag-search). Largely vestigial — REST
# API does not route through it for production search. Kept for direct
# gRPC clients and historical compatibility.
GRPC_SERVER_HOST=kgrag-search
GRPC_SERVER_PORT=50051

# ── Auth Service ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM / Gemini ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-3.1-flash-lite-preview
LLM_API_VERSION=v1beta
LLM_INSTRUCTOR_MODE=json_mode
LLM_ENABLED=true
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=1500
LLM_RATE_LIMIT_INTERVAL=60

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_MODE=true

# ── Worker concurrency ───────────────────────────────────────────────────────
ENTITY_EXTRACTION_MAX_WORKERS=30
SUMMARIZATION_MAX_WORKERS=30
PARSER_MAX_WORKERS=4
PARSER_TIMEOUT_SECONDS=60
DOC_PROCESSING_WORKERS=4

# ── gRPC Server ──────────────────────────────────────────────────────────────
GRPC_MAX_WORKERS=10
GRPC_IDEMPOTENCY_CACHE_TTL=3600
GRPC_ENABLE_HEALTH_CHECK=true

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TELEMETRY_DISABLED=true
COGNEE_ENABLED=true
ENABLE_DOCUMENT_CANONICALISATION=false
DOCKER_REGISTRY=local
VERSION=latest

# ══════════════════════════════════════════════════════════════════════════════
# HOST-SIDE DEV (running scripts on your laptop against the running stack)
# These are COMMENTED OUT on purpose — uncommenting them would override the
# container-targeted values above and break in-container services.
# Use them only when running Python scripts from your host machine.
# ══════════════════════════════════════════════════════════════════════════════
#
# QDRANT_HOST=localhost
# NEO4J_URI=bolt://localhost:7687
# POSTGRES_URL=postgresql://kgrag:${POSTGRES_PASSWORD}@localhost:5432/kgrag_auth
# AUTH_SERVICE_URL=http://localhost:8001
# GRPC_SERVER_HOST=localhost
# COGNEE_REDIS_URL=redis://localhost:6379
# KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# DEV ONLY — when true, /register auto-activates accounts and skips email verification.
# NEVER set this to true in production.
SKIP_EMAIL_VERIFICATION=false

# Cognee multi-user access control. Required to be `false` for self-hosted Neo4j.
ENABLE_BACKEND_ACCESS_CONTROL=false
