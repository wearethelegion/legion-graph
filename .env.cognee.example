# ============================================================
# Alternative LLM-provider recipe — OpenRouter + FastEmbed
# ============================================================
#
# This file is a recipe, NOT a standalone environment file. The stack only
# loads `.env` (one file, root of repo). To use this recipe:
#
#   1. Copy your existing .env (or .env.example) to a working file.
#   2. Replace the LLM_* and EMBEDDING_* blocks in that file with the
#      values shown below, plus set LLM_API_KEY to your OpenRouter key.
#   3. Keep the rest of your .env (Postgres, Neo4j, Redis, Kafka) unchanged.
#
# Why this recipe exists:
#   - OpenRouter has a free tier including Llama 3.3 70B — useful for
#     cost-free evaluation without a Google Cloud / Gemini account.
#   - FastEmbed runs locally inside the container — no embedding API
#     needed, fully air-gappable.
#
# Validation status:
#   - This recipe has NOT been end-to-end tested against the kgrag stack.
#     The only validated configuration is Gemini 3.1 Flash Lite Preview
#     (see README.md "Validation status"). Switching to this recipe will
#     likely require prompt and instructor-mode tuning before it works
#     cleanly. Treat it as a starting point, not a turnkey swap.
# ============================================================

# ── gRPC Server ─────────────────────────────────────────────
# Port the cognee gRPC server listens on (default: 50052)
GRPC_PORT=50052

# ── Neo4j / DozerDB ─────────────────────────────────────────
# Bolt connection URI
NEO4J_URI=bolt://neo4j:7687

# Username (default: neo4j)
NEO4J_USERNAME=neo4j

# Password (REQUIRED)
NEO4J_PASSWORD=your_neo4j_password_here

# Neo4j database name used exclusively by cognee (default: cognee)
COGNEE_NEO4J_DATABASE=cognee

# ── LLM — OpenRouter free Llama 3.3 70B ─────────────────────
# Provider must be "openai" so cognee uses the openai-compatible client
LLM_PROVIDER=openai

# Use the openrouter/ LiteLLM prefix so requests are routed via OpenRouter
LLM_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# Your OpenRouter API key (REQUIRED). Get one at https://openrouter.ai/keys
# Note: legion-graph reads ONLY LLM_API_KEY. There is no separate
# OPENROUTER_API_KEY variable in the code — set LLM_API_KEY to your
# OpenRouter key here. The historical GEMINI_API_KEY slot in the main
# .env is wired as LLM_API_KEY by compose; if you replace its value with
# your OpenRouter key, you can use the main .env as-is.
LLM_API_KEY=sk-or-v1-your_openrouter_api_key_here

# OpenRouter OpenAI-compatible endpoint
LLM_ENDPOINT=https://openrouter.ai/api/v1

# Instructs cognee to use JSON mode for structured LLM outputs
LLM_INSTRUCTOR_MODE=json

# ── Embeddings — fastembed (local, no API key required) ─────
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store (Qdrant) ─────────────────────────────────────
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://qdrant:6333
# Leave empty if Qdrant has no API key configured
QDRANT_API_KEY=

# ── Metadata Store (Postgres) ─────────────────────────────────
DB_PROVIDER=postgres
DB_HOST=postgres
DB_PORT=5432
# Dedicated Postgres database for cognee metadata (separate from kgrag_auth)
DB_NAME=cognee
DB_USERNAME=kgrag
# REQUIRED — must match POSTGRES_PASSWORD in your main .env
DB_PASSWORD=your_postgres_password_here

# ── Redis Cache ───────────────────────────────────────────────
# Uses DB index 1 to avoid collision with the auth service (DB 0)
REDIS_URI=redis://:your_redis_password_here@redis:6379/1

# ── Telemetry ────────────────────────────────────────────────
# Set to "true" to disable cognee telemetry (recommended for self-hosted)
TELEMETRY_DISABLED=true
