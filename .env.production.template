# ============================================================================
# legion-graph — Production Hardening Checklist (env template)
# ============================================================================
#
# This file is a hardened variant of `.env.example` for production-style
# deployments. Copy it, fill in real values, and use it as your `.env`:
#
#   cp .env.production.template .env
#   # edit .env with real values
#   make up
#
# What "production hardening" means here:
#   - Every secret has a strong unique value (not the dev defaults).
#   - Operator-side concerns (TOTP encryption, JWT, embedding key rotation)
#     are made explicit.
#   - Dev-only convenience flags (SKIP_EMAIL_VERIFICATION) are off.
#
# What this file is NOT:
#   - It is NOT a GitHub Actions secret manifest. This repository does not
#     ship GitHub Actions workflows; deploy automation is your responsibility.
#   - It is NOT a docker-compose.prod.yml driver. There is only one compose
#     file: `docker/docker-compose.yml`.
#   - It does NOT configure reverse proxies, TLS, Let's Encrypt, SSH, or any
#     other deploy-time infrastructure. Those are outside the scope of this
#     repository — operators are expected to wire their own ingress, certs,
#     and orchestration.
#
# Convention:
#   [REQUIRED]  — stack will not start without this.
#   [OPTIONAL]  — has a sensible default in compose; only set to override.
#   [SECRET]    — sensitive; store in your own secret manager, not committed.
#   [TUNING]    — performance / behaviour knob with a default.
#
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE & INFRASTRUCTURE CREDENTIALS  [REQUIRED] [SECRET]
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL — application DB (auth, projects, brain_* tables).
POSTGRES_PASSWORD=your_strong_postgres_password

# Neo4j / DozerDB — graph database. Used for both the `kgrag` and `cognee`
# logical databases inside the same Neo4j instance.
NEO4J_PASSWORD=your_strong_neo4j_password

# Redis — token blacklist, ephemeral state, cognee staging cache.
REDIS_PASSWORD=your_strong_redis_password

# Qdrant API key — leave empty if Qdrant is on a private network with no
# authentication enabled. Set if you front Qdrant with auth.
QDRANT_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & ENCRYPTION  [REQUIRED] [SECRET]
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — minimum 32 characters of high-entropy data. Used by
# kgrag-auth (issuer) and kgrag-cognee (verifier via COGNEE_JWT_SECRET_KEY).
JWT_SECRET_KEY=your_strong_jwt_secret_min_32_chars
COGNEE_JWT_SECRET_KEY=your_strong_jwt_secret_min_32_chars

# TOTP encryption key — encrypts 2FA seeds in the database. Once set,
# NEVER rotate this value: existing 2FA seeds become unreadable and all
# 2FA-enabled users will be locked out. Read by auth/services/totp_service.py.
TOTP_ENCRYPTION_KEY=your_strong_totp_encryption_key


# ─────────────────────────────────────────────────────────────────────────────
# LLM PROVIDER  [REQUIRED for ingest and search to function]
# ─────────────────────────────────────────────────────────────────────────────
#
# legion-graph uses LiteLLM and accepts any LiteLLM-supported provider.
# Only the Gemini configuration below has been end-to-end validated against
# this stack. Switching providers will work in principle but will likely
# require tuning of prompts, instructor mode, and embedding dimensions.
# See README.md "LLM provider choice" for the full provider matrix.

# Universal LLM API-key slot. Despite the historical variable name, this
# carries the key for whichever provider you configure below. docker-compose
# fans it out to all services as LLM_API_KEY.
GEMINI_API_KEY=your_llm_provider_api_key

# Validated default — Gemini 3.1 Flash Lite Preview via the Gemini API.
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-3.1-flash-lite-preview
LLM_INSTRUCTOR_MODE=json_mode

# [OPTIONAL] Comma-separated list of additional API keys for round-robin
# rotation across embedding requests, to avoid per-key quota limits.
# Read by graph_services/patches/cognee/index_data_points.py.
# Falls back to GEMINI_API_KEY (single key) when unset.
# Example: EMBEDDING_API_KEYS=AIzaSy_key1,AIzaSy_key2,AIzaSy_key3
EMBEDDING_API_KEYS=

# Embedding model — must match the dimensions of your Qdrant collections.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072


# ─────────────────────────────────────────────────────────────────────────────
# EMAIL VERIFICATION  [OPTIONAL] [SECRET]
# ─────────────────────────────────────────────────────────────────────────────
# legion-graph integrates with Infobip for transactional email delivery
# (user registration confirmation). If you do not configure these, set
# SKIP_EMAIL_VERIFICATION=true below and email flows are bypassed.

INFOBIP_API_KEY=
INFOBIP_BASE_URL=
VERIFICATION_FROM_EMAIL=noreply@your-domain.example


# ─────────────────────────────────────────────────────────────────────────────
# GITHUB INTEGRATION  [OPTIONAL]
# ─────────────────────────────────────────────────────────────────────────────
# Used by kgrag-code-preprocessor to fetch private repositories during code
# ingest. Stored per-project in postgres (projects.github_token). Falls back
# to this env value if a project has no token set.
GITHUB_TOKEN=


# ─────────────────────────────────────────────────────────────────────────────
# COGNEE  [REQUIRED] [TUNING]
# ─────────────────────────────────────────────────────────────────────────────

# Neo4j logical database that cognee uses for graph storage. Must be created
# explicitly: `CREATE DATABASE cognee IF NOT EXISTS` against Neo4j's `system`
# database before first cognee run.
COGNEE_NEO4J_DATABASE=cognee

# Cognee multi-user access control. Must remain `false` for self-hosted Neo4j
# without enterprise authentication.
ENABLE_BACKEND_ACCESS_CONTROL=false


# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY  [TUNING]
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
TELEMETRY_DISABLED=true


# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION SAFETY FLAGS  [REQUIRED for production]
# ─────────────────────────────────────────────────────────────────────────────

# MUST be `false` in production. When `true`, /register auto-activates
# accounts and skips email verification — useful for local dev, dangerous
# in any reachable environment.
SKIP_EMAIL_VERIFICATION=false


# ─────────────────────────────────────────────────────────────────────────────
# OUT OF SCOPE FOR THIS REPOSITORY
# ─────────────────────────────────────────────────────────────────────────────
# The following concerns are NOT addressed by this repository and must be
# wired by the operator using their own tooling:
#
#   - TLS termination, certificate management (Let's Encrypt, ACM, etc.)
#   - Reverse-proxy / ingress (nginx, Traefik, ALB, ...)
#   - HTTP basic-auth or SSO for admin UIs (Neo4j browser, Qdrant dashboard)
#   - SSH and remote-deploy automation
#   - Container registry credentials (Docker Hub, ECR, GHCR)
#   - Backup, snapshot, and disaster-recovery procedures
#   - Centralised logging, metrics, alerting (Prometheus, Loki, Datadog, ...)
#   - Network policies, firewalls, VPC peering
#
# Operators are expected to layer these on top of the open-source release.
